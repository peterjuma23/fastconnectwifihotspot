# ============================================================
# FastConnect Internet - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ──────────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────────
DB_HOST=mysql
DB_USER=fastconnect
DB_PASSWORD=ChangeMe123!
DB_ROOT_PASSWORD=ChangeRootMe123!
DB_NAME=fastconnect_db

# ──────────────────────────────────────────────────────────
# Redis Configuration
# ──────────────────────────────────────────────────────────
REDIS_PASSWORD=RedisChangeMe123!
REDIS_URL=redis://:RedisChangeMe123!@redis:6379

# ──────────────────────────────────────────────────────────
# M-Pesa Daraja API (Safaricom)
# ──────────────────────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_PASSKEY=your_passkey_here
MPESA_SHORTCODE=174379

# Environment: sandbox (testing) or production (live)
MPESA_ENVIRONMENT=sandbox

# Public callback URL (must be HTTPS in production)
MPESA_CALLBACK_URL=https://wifi.fastconnect.co.ke

# ──────────────────────────────────────────────────────────
# JWT Authentication (RS256)
# ──────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
# Copy keys with \n replaced as actual newlines
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...\n-----END PUBLIC KEY-----"

# Refresh token secret (minimum 32 characters)
JWT_REFRESH_SECRET=your_refresh_secret_32chars_minimum

# ──────────────────────────────────────────────────────────
# Encryption (AES-256-CBC)
# ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=64_char_hex_encryption_key_for_aes_256_cbc

# Cookie signing secret (minimum 32 characters)
COOKIE_SECRET=your_cookie_secret_32chars_minimum

# ──────────────────────────────────────────────────────────
# Backup Configuration
# ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=another_64_char_hex_for_backups
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30

# Optional: AWS S3 Backup (if you want cloud backups)
BACKUP_S3_BUCKET=your-backup-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ──────────────────────────────────────────────────────────
# Application URLs
# ──────────────────────────────────────────────────────────
FRONTEND_URL=https://wifi.fastconnect.co.ke
WEBSOCKET_URL=wss://wifi.fastconnect.co.ke

# ──────────────────────────────────────────────────────────
# MikroTik Router Configuration
# ──────────────────────────────────────────────────────────
# Default hotspot profile name (create this on your routers)
HOTSPOT_PROFILE=fastconnect

# ──────────────────────────────────────────────────────────
# Seed Data (First-time setup)
# ──────────────────────────────────────────────────────────
# Default admin password (change after first login!)
SEED_ADMIN_PASSWORD=Admin@FastConnect2024!

# ──────────────────────────────────────────────────────────
# Node Environment
# ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000